llm:
  provider: "ollama"                     
  model_name: "qwen2.5:7b-instruct-fp16" 
  openai_api_key: "sk-..."               # ✅ 若使用 openai provider 才需生效
  openai_base_url: "https://api.deepseek.com/v1"
  host: "http://localhost:11434"         
  options:
    num_ctx: 32768

embedding:
  provider: "ollama"                     
  model_name: "BAAI/bge-m3"                   # 支持: bge-m3, text2vec, text-embedding-ada-002, all-MiniLM-L6-v2
  host: "http://localhost:11434"

matching:
  use_keyword_filter: true               # 是否启用关键词实体校验
  similarity_strategy: "summary_vector"  # 相似度策略: summary_vector, max_sentence, topic_center
  min_similarity_threshold: 0.3          # 最低匹配阈值

document:
  input_dir: "./data"                   
  chunk_size: 1000                      # 每个块的最大字符数
  chunk_overlap: 200                    # 块之间的重叠字符数
  allowed_types: [".docx", ".json"]     
  similarity_threshold: 0.80            # 主题相似度阈值
  redundancy_threshold: 0.95            # 冗余过滤阈值

output:
  base_dir: "./result"                  
  work_name: null                       
  overwrite: false                      
  reuse_cache: true                     

graph:
  top_k_relations: 5                    

vector:                                 # ✅ 修正：应为 vector 而不是 index
  index_type: "IVF"                     # ✅ 可选: Flat, IVF, HNSW
  nlist: 100                            # IVF专用
  nprobe: 10                            # IVF查询时使用
  ef_search: 32                         # HNSW 查询时使用

classifier:
  generate_samples: 300                # ✅ 已采用 base_classifier_samples.jsonl
  bert_model: "bert-base-chinese"      # BERT模型名称
  finetune:
    enable: true
    base_model: "./result/base"        # ✅ fine-tune 用 base model 路径
    data: "./result/base_classifier_samples.jsonl"
    output: "./result/fine_tuned"
    model: "bert-base-chinese"

rerank:
  enabled: true                        # 是否启用重排序
  method: "simple"                     # 重排序方法: simple, llm
  rerank_weights:                      # 重排序权重配置
    vector: 0.4                        # 向量相似度权重
    tfidf: 0.3                         # TF-IDF相似度权重
    overlap: 0.2                       # 关键词重叠权重
    diversity: 0.1                     # 多样性权重

query:
  cache_enabled: true                  
  max_history: 1000
