# 示例配置文件：config.yaml.example

llm:
  provider: "openai"  # 可选: "openai", "ollama"
  model_name: "gpt-4"
  embedding_model: "text-embedding-ada-002"
  openai_api_key: "sk-xxx"  # 请替换为你的 OpenAI 密钥
  openai_base_url: "https://api.openai.com/v1"  # 默认即可
  ollama_host: "http://localhost:11434"  # 本地 Ollama 服务

document:
  input_dir: "./data"
  chunk_size: 1000
  chunk_overlap: 200
  allowed_types: [".docx", ".json"]

output:
  base_dir: "./result"
  work_name: null       # 使用 null 表示自动选最新
  overwrite: false
  reuse_cache: true

graph:
  top_k_relations: 5    # 每个chunk最多抽取几条关系

index:
  use_faiss: true
  embedding_dim: 1536   # 根据你的嵌入模型选择维度

classifier:
  model_path: "query_classifier.pkl"
  enable_continual_learning: true
  generate_samples: 30  # 生成训练样本数

query:
  cache_enabled: true
  max_history: 1000
